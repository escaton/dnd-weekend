{
  "name": "@dnd-weekend/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js && esbuild src/migrate.ts --bundle --platform=node --format=esm --outfile=dist/migrate.js",
    "start": "node dist/index.js",
    "db:migrate": "tsx --env-file=../../.env src/migrate.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-weekend/api": "workspace:*",
    "@hono/node-server": "^2.0.6",
    "@trpc/server": "^11.18.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.1-rc"
  }
}
