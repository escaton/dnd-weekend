# Database (Supabase Postgres — direct connection for migrations only)
# Not needed at Worker runtime — Hyperdrive manages the connection.
# Used by: pnpm --filter @dnd-weekend/api db:migrate
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# Cloudflare environment — which wrangler env block to use (test or prod)
# Used by: vite.config.ts → @cloudflare/vite-plugin (selects env.test or env.prod)
CLOUDFLARE_ENV=test

# Hyperdrive local dev connection (read by apps/web/vite.config.ts via loadEnv,
# then set on process.env for @cloudflare/vite-plugin). Binding name is HYPERDRIVE.
# Not needed at Worker runtime — only for local `vite dev`. Same value as DATABASE_URL.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://postgres:YOUR_PASSWORD@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# tldraw SDK license key. Auto-detected by tldraw from VITE_TLDRAW_LICENSE_KEY.
# Dev mode (localhost/HTTP) works without a key. Required for production (HTTPS).
# Get one at https://tldraw.dev/pricing (hobby = free w/ watermark; trial = 14-day no watermark).
VITE_TLDRAW_LICENSE_KEY=
